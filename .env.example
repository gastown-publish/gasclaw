# Required: Colon-separated Kimi API keys for Gastown agents
GASTOWN_KIMI_KEYS=sk-kimi-key1:sk-kimi-key2:sk-kimi-key3

# Required: Kimi API key for OpenClaw LLM (separate pool)
OPENCLAW_KIMI_KEY=sk-kimi-openclaw-key

# Required: Telegram bot token
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Required: Telegram user ID for allowlist
TELEGRAM_OWNER_ID=123456789

# Optional: Git URL or path for the rig (default: /project)
# GT_RIG_URL=/project

# Optional: Number of crew workers (default: 6)
# GT_AGENT_COUNT=6

# Optional: Directory for git activity checks (default: /project)
# PROJECT_DIR=/project

# Optional: Health check interval in seconds (default: 300)
# MONITOR_INTERVAL=300

# Optional: Max seconds between commits/PRs (default: 3600)
# ACTIVITY_DEADLINE=3600

# Optional: Dolt SQL server port (default: 3307)
# DOLT_PORT=3307

# Optional: Directory for git activity checks (default: /project)
# PROJECT_DIR=/project

# Optional: Log level - DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
