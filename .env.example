# === Required ===

# Colon-separated Kimi API keys for Gastown agents
GASTOWN_KIMI_KEYS=sk-kimi-key1:sk-kimi-key2:sk-kimi-key3

# Kimi API key for OpenClaw overseer (separate pool, never shared with agents)
OPENCLAW_KIMI_KEY=sk-kimi-openclaw-key

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Telegram user ID for owner (numeric, from @userinfobot)
TELEGRAM_OWNER_ID=123456789

# === Optional ===

# Git URL or path for the rig (default: /project)
# GT_RIG_URL=/project

# Number of crew workers (default: 6)
# GT_AGENT_COUNT=6

# Directory for git activity checks (default: /project)
# PROJECT_DIR=/project

# Health check interval in seconds (default: 300)
# MONITOR_INTERVAL=300

# Max seconds between commits/PRs (default: 3600)
# ACTIVITY_DEADLINE=3600

# Dolt SQL server port (default: 3307)
# DOLT_PORT=3307

# OpenClaw gateway port (default: 18789)
# GATEWAY_PORT=18789

# Log level - DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# YAML config file path (default: /workspace/config/gasclaw.yaml)
# GASCLAW_CONFIG=/workspace/config/gasclaw.yaml

# === Telegram Allowlists (colon-separated numeric IDs) ===

# Additional Telegram user IDs allowed to DM the bot (owner is always allowed)
# TELEGRAM_ALLOW_IDS=111111111:222222222

# Telegram group/supergroup chat IDs (negative numbers, e.g. -1001234567890)
# TELEGRAM_GROUP_IDS=-1001234567890:-1009876543210

# === Agent Identity ===

# Agent ID used in OpenClaw config (default: main)
# AGENT_ID=main

# Display name for the overseer agent (default: Gasclaw Overseer)
# AGENT_NAME=Gasclaw Overseer

# Emoji for the overseer agent (default: factory)
# AGENT_EMOJI=🏭

# === Maintainer container only ===
# These are used by maintainer/docker-compose.yml

# GitHub personal access token (for PR/issue operations)
# GITHUB_TOKEN=ghp_xxxxx

# Single Kimi key for the maintainer agent
# KIMI_API_KEY=sk-kimi-xxxxx

# Telegram chat ID for notifications (often same as TELEGRAM_OWNER_ID)
# TELEGRAM_CHAT_ID=123456789
